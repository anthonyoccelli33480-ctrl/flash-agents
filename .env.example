# Clé API Cerebras — https://cloud.cerebras.ai
# Tu peux aussi la configurer via l'onboarding dans l'app (enregistrée ici, gitignoré).
# ⚠️ PAS dans .venv — .venv = paquets Python uniquement.
CEREBRAS_API_KEY=your_key_here

# Intervalle minimum entre requêtes (free tier ≈ 5 req/min → 15s safe)
FLASH_RATE_INTERVAL_SEC=15

# Port backend
FLASH_PORT=8787